# Data source: "seed" (local taxonomy, default) or "strapi" (live CMS)
DATA_SOURCE=seed

# Strapi (when DATA_SOURCE=strapi)
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=

# Lead pipeline (email-first, Strapi best-effort)
LEAD_TO_EMAIL=nhu.trang@az-technology.vn
RESEND_API_KEY=

# Revalidation webhook (Strapi -> Next)
REVALIDATE_SECRET=

# Site
NEXT_PUBLIC_SITE_URL=https://az-technology.vn

# ---------------------------------------------------------------------------
# Cloudflare R2 media storage (S3-compatible). Set these to store CMS uploads
# in R2 instead of the CMS container's local disk. Read by docker-compose and
# passed to the cms service. Leave blank to keep local-disk uploads.
#   R2_ENDPOINT          https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   R2_ACCESS_KEY_ID     R2 API token Access Key ID
#   R2_SECRET_ACCESS_KEY R2 API token Secret Access Key
#   R2_BUCKET            bucket name (e.g. az-technology-media)
#   R2_PUBLIC_URL        public bucket URL, no trailing slash
#                        (r2.dev dev URL or a custom domain bound to the bucket)
# ---------------------------------------------------------------------------
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
