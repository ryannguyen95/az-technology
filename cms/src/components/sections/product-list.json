{
  "collectionName": "components_sections_product_lists",
  "info": {
    "displayName": "Khối danh sách sản phẩm",
    "icon": "bulletList",
    "description": "Một khối trang chủ hiển thị danh sách sản phẩm, có thể chia thành nhiều mục con."
  },
  "options": {},
  "attributes": {
    "title": { "type": "string", "required": true },
    "products": {
      "type": "relation",
