      "target": "api::product.product"
    },
    "subsections": {
      "type": "component",
      "repeatable": true,
      "component": "home.subsection"
    },
    "parentCategory": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::parent-category.parent-category"
    }
  }
}
