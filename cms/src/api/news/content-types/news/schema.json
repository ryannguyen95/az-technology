{
  "kind": "collectionType",
  "collectionName": "news_posts",
  "info": { "singularName": "news", "pluralName": "news-posts", "displayName": "News Post" },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "excerpt": { "type": "text" },
    "cover": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "body": { "type": "richtext" },
    "newsCategory": { "type": "enumeration", "enum": ["chia-se", "tin-cong-nghe", "thu-thuat", "tin-cong-ty"], "default": "tin-cong-nghe" }
  }
}
