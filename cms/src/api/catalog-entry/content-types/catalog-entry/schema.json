{
  "kind": "collectionType",
  "collectionName": "catalog_entries",
  "info": {
    "singularName": "catalog-entry",
    "pluralName": "catalog-entries",
    "displayName": "Catalog Entry",
    "description": "Unified entry: category, solution, service, software, or product."
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": {},
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "kind": {
      "type": "enumeration",
      "enum": ["category", "solution", "service", "software", "product"],
      "required": true,
      "default": "category"
    },
    "order": { "type": "integer", "default": 0 },
    "icon": { "type": "string" },
    "tone": { "type": "enumeration", "enum": ["blue", "cyan", "green", "navy", "red"], "default": "blue" },
    "badge": { "type": "string" },
    "summary": { "type": "text" },
    "coverImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "gallery": { "type": "media", "multiple": true, "allowedTypes": ["images"] },
    "featured": { "type": "boolean", "default": false },
    "priceMode": { "type": "enumeration", "enum": ["show", "contact"], "default": "contact", "required": true },
    "priceOld": { "type": "integer" },
    "priceNew": { "type": "integer" },
    "priceFromLabel": { "type": "string" },
    "rating": { "type": "integer", "min": 0, "max": 5 },
    "reviews": { "type": "integer" },
    "brands": { "type": "relation", "relation": "manyToMany", "target": "api::brand.brand", "inversedBy": "entries" },
    "parent": { "type": "relation", "relation": "manyToOne", "target": "api::catalog-entry.catalog-entry", "inversedBy": "children" },
    "children": { "type": "relation", "relation": "oneToMany", "target": "api::catalog-entry.catalog-entry", "mappedBy": "parent" },
    "seo": { "type": "component", "repeatable": false, "component": "seo.meta" },
    "body": {
      "type": "dynamiczone",
      "components": [
        "blocks.rich-text",
        "blocks.feature-list",
        "blocks.spec-accordion",
        "blocks.process-steps",
        "blocks.faq",
        "blocks.cta"
      ]
    }
  }
}
