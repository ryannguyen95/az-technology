{
  "kind": "collectionType",
  "collectionName": "entry_kinds",
  "info": {
    "singularName": "entry-kind",
    "pluralName": "entry-kinds",
    "displayName": "Entry Kind",
    "description": "Editable list of catalog-entry kinds (category, solution, service, software, product…)."
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "label": { "type": "string", "required": true },
    "key": { "type": "string", "required": true, "unique": true },
    "order": { "type": "integer", "default": 0 },
    "entries": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::catalog-entry.catalog-entry",
      "mappedBy": "kind"
    }
  }
}
