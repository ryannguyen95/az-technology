# CMS (Strapi v5) — local development image.
# Node 22: Strapi requires 20–24 (rejects 25+). npm is the locked manager here.
FROM node:22-bookworm-slim

# Build tools for native modules (better-sqlite3 falls back to source if no prebuilt).
RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 make g++ \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# yarn (classic) ships with the node image. No yarn.lock yet, so plain install
# resolves and generates one; it'll be persisted via the bind mount.
COPY package.json yarn.lock* ./
RUN yarn install

COPY . .

EXPOSE 1337

CMD ["yarn", "develop"]
